# Copy to server/.env for local testing (server/.env is gitignored).
# On Render, set these as the Web Service's Environment Variables instead.

# Airtable personal access token with data.records:write on your base. SECRET.
AIRTABLE_TOKEN=pat_your_personal_access_token_here

# Your Airtable base id (starts with "app...").
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table name (defaults to "Waitlist" if omitted).
AIRTABLE_TABLE=Waitlist

# Allowed site origin(s), comma-separated. Use your live URL in production,
# e.g. https://clarivance-ai.onrender.com  (use * only for quick local testing).
ALLOWED_ORIGINS=*
